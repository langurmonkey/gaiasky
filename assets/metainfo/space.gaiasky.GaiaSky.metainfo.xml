<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>space.gaiasky.GaiaSky</id>
  <url type="homepage">https://gaiasky.space</url>
  <url type="help">http://docs.gaiasky.space</url>
  <url type="bugtracker">https://codeberg.org/gaiasky/gaiasky/issues</url>

  <branding>
    <color type="primary" scheme_preference="light">#ffffc9</color>
    <color type="primary" scheme_preference="dark">#4e5d74</color>
    </branding>

  <name>Gaia Sky</name>
  <summary>Explore the universe in 3D</summary>

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <developer_name>Zentrum für Astronomie der Universität Heidelberg</developer_name>

  <provides>
    <id>de.uni_heidelberg.zah.GaiaSky</id>
  </provides>

  <replaces>
    <id>de.uni_heidelberg.zah.GaiaSky</id>
  </replaces>

  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
    <control>gamepad</control>
  </recommends>

  <description>
    <p>
      Gaia Sky is an astronomy visualization platform for desktop and VR that runs on Linux, Windows and macOS. It is developed in the framework of ESA&apos;s Gaia mission to chart about 1 billion stars of our Galaxy in the Gaia group of the Astronomisches Rechen-Institut (ZAH, Universität Heidelberg). Explore the Solar System, the Milky Way, and even the most distant galaxies of our Universe with up-to-date, real scientific data.
      </p>
    </description>

  <releases>

    <release version="3.7.4" date="2026-06-17" urgency="high">
      <url>https://gaiasky.space/news/2026/gaiasky_3.7.4</url>
      <description>
        <p>This release presents an overhaul in the atmospheric scattering model and includes important bugfixes for the keyframe system:</p>
        <ul>
          <li>Unify atmospheric scattering ground and sky paths that uses Burneton's approximation for the density scale.</li>
          <li>Use glow and transmittance for correct blending.</li>
          <li>Consider terrain elevation in scattering calculations.</li>
          <li>Add ozone absorption to atmospheric scattering, and expose it in the procedural planet generation dialog.</li>
          <li>Fix keyframe lines and points being invisible.</li>
          <li>Fix locale initialization.</li>
          <li>Fix compute shader support check by adding SSBO extension lookup.</li>
          <li>Fix dependency on Java >=26 in AUR package.</li>
          <li>Fix directory selection in file picker.</li>
          <li>Update to libGDX 1.14.2.</li>
        </ul>
      </description>
      </release>
    </releases>

  <content_rating type="oars-1.1" />

